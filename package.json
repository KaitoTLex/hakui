{
  "name": "hakui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:backend": "PYTHONPATH=backend python3 backend/run.py",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node scripts/start.mjs",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run && npm run test:backend",
    "test:backend": "PYTHONPATH=backend python3 -m unittest discover -s backend/tests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "idb": "^8.0.3"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.5.7",
    "@sveltejs/kit": "^2.70.1",
    "@types/node": "^24.10.0",
    "fake-indexeddb": "^6.2.5",
    "svelte": "^5.56.6",
    "svelte-check": "^4.7.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22"
  }
}
