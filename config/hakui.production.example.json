{
  "server": {
    "host": "127.0.0.1",
    "port": 3004,
    "origin": "https://hakui.kaitotlex.systems",
    "bodySizeLimit": "15M"
  },
  "backend": {
    "host": "127.0.0.1",
    "port": 3005
  },
  "storage": {
    "databasePath": "/var/lib/hakui/hakui.sqlite",
    "backupDirectory": "/var/lib/hakui/backups",
    "initialCsvPath": "/var/lib/hakui/CurrentFinances.csv"
  },
  "trip": {
    "timezone": "Asia/Tokyo",
    "currency": "JPY"
  },
  "receipts": {
    "maxUploadBytes": 12000000,
    "maxPixels": 25000000,
    "jpegMaxEdge": 1600,
    "jpegQuality": 0.78
  },
  "ocr": {
    "languages": ["jpn", "eng"],
    "timeoutSeconds": 30,
    "maxConcurrentJobs": 1,
    "translationFallback": true
  }
}
